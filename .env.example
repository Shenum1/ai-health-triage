# ============================================================
#  MediTriage AI — Environment Configuration
#  Copy this file to .env and fill in your values
#  DO NOT commit .env to version control
# ============================================================

# ── AI (Groq - FREE) ─────────────────────────────────────────
# Get your FREE key at: https://console.groq.com/
# No credit card required!
GROQ_API_KEY=your_groq_api_key_here

# ── Authentication ───────────────────────────────────────────
# Generate a strong random secret, e.g.:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_here_generate_with_crypto_randomBytes_64
JWT_EXPIRES_IN=7d

# ── Server ───────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Database (Supabase Postgres) ─────────────────────────────
# Get from: Supabase Dashboard → Settings → Database → Connection pooling
# Use Transaction mode (port 6543)
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# ── Supabase Auth ─────────────────────────────────────────────
# All three from: Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ── Admin ─────────────────────────────────────────────────────
# Secret used to create the first admin account via POST /api/doctor/admin/seed
# Change this to something random before deploying
ADMIN_SEED_SECRET=change-this-to-a-random-secret
